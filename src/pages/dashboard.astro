---
// src/pages/dashboard.astro
import Layout from "../layouts/Layout.astro";

// 1. Verificación de seguridad de tu App
const isAuthenticated =
    Astro.cookies.get("app_session")?.value === "authenticated";
if (!isAuthenticated) return Astro.redirect("/");

const token = Astro.cookies.get("meli_access_token")?.value;

// ... (Verificaciones de auth iniciales igual)

let products: any[] = [];
let error: string | null = null;

if (token) {
  try {
    // 1. Datos del usuario (esto ya sabemos que funciona)
    const meRes = await fetch('https://api.mercadolibre.com/users/me', {
      headers: { 'Authorization': `Bearer ${token}` }
    });
    const meData = await meRes.json();
    const userId = meData.id;

    // 2. ESTRATEGIA NUEVA: Usamos el endpoint de LISTADO DE ITEMS del usuario
    // Este no es un "search", es una lista directa de IDs.
    const listRes = await fetch(`https://api.mercadolibre.com/users/${userId}/items/search?status=active`, {
      headers: { 'Authorization': `Bearer ${token}` }
    });
    const listData = await listRes.json();
    
    // Si no hay activos, intentamos traer pausados por separado
    let ids = listData.results || [];
    
    if (ids.length === 0) {
      const pausedRes = await fetch(`https://api.mercadolibre.com/users/${userId}/items/search?status=paused`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const pausedData = await pausedRes.json();
      ids = pausedData.results || [];
    }

    // 3. Obtener detalles de esos IDs
    if (ids.length > 0) {
      // Tomamos los primeros 20 para asegurar que cargue rápido
      const itemsRes = await fetch(`https://api.mercadolibre.com/items?ids=${ids.slice(0, 20).join(',')}`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      products = await itemsRes.json();
    }

    if (products.length === 0) {
      error = "No se encontraron productos. Nickname: " + meData.nickname;
    }

  } catch (e: any) {
    console.error("Error:", e);
    error = "Error de conexión con MeLi.";
  }
}

const clientId = import.meta.env.MELI_CLIENT_ID;
const redirectUri = encodeURIComponent(import.meta.env.MELI_REDIRECT_URI);
const meliAuthUrl = `https://auth.mercadolibre.cl/authorization?response_type=code&client_id=${clientId}&redirect_uri=${redirectUri}`;
---

<Layout title="Dashboard | NGG Stock">
    <nav class="bg-white border-b border-gray-200 px-4 py-2.5">
        <div
            class="flex flex-wrap justify-between items-center mx-auto max-w-screen-xl"
        >
               <h1 class="text-2xl font-bold text-heading md:text-4xl lg:text-5xl">
            <span class="text-transparent bg-clip-text bg-gradient-to-r to-emerald-600 from-sky-400">
                NGG STOCK
            </span>
        </h1>
            <a
                href="/api/auth/logout"
                class="text-sm text-gray-500 hover:text-red-600"
                >Cerrar Sesión</a
            >
        </div>
    </nav>

    <main class="p-4 md:p-8 max-w-screen-xl mx-auto">
        {
            !token ? (
                <div class="p-4 mb-4 text-yellow-800 border border-yellow-300 rounded-lg bg-yellow-50">
                    <h3 class="text-lg font-medium">Vincular Mercado Libre</h3>
                    <p class="mb-4 text-sm">
                        Conecta tu cuenta para empezar a gestionar el stock.
                    </p>
                    <a
                        href={meliAuthUrl}
                        class="text-white bg-blue-700 hover:bg-blue-800 font-medium rounded-lg text-sm px-5 py-2.5 inline-block"
                    >
                        Conectar ahora
                    </a>
                </div>
            ) : (
                <div class="relative overflow-x-auto shadow-md sm:rounded-lg">
                    <p class="text-xs text-gray-400 mb-2">
                        Mostrando {products.length} productos de tu cuenta.
                        Token: {token.substring(0, 10)}...
                    </p>
                    <table class="w-full text-sm text-left text-gray-500">
                        <thead class="text-xs text-gray-700 uppercase bg-gray-50">
                            <tr>
                                <th class="px-6 py-3">Producto</th>
                                <th class="px-6 py-3">Precio</th>
                                <th class="px-6 py-3 text-center">Stock</th>
                                <th class="px-6 py-3">Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            {products && products.length > 0 ? (
                                products.map((item) => (
                                    <tr class="bg-white border-b hover:bg-gray-50">
                                        {/* ... tu código de la fila ... */}
                                    </tr>
                                ))
                            ) : (
                                <tr>
                                    <td
                                        colspan="4"
                                        class="px-6 py-10 text-center text-gray-500 italic"
                                    >
                                        No se encontraron productos o la cuenta
                                        no tiene stock activo.
                                    </td>
                                </tr>
                            )}
                            {products.map((item) => (
                                <tr class="bg-white border-b hover:bg-gray-50">
                                    <th
                                        scope="row"
                                        class="flex items-center px-6 py-4 text-gray-900 whitespace-nowrap"
                                    >
                                        <img
                                            class="w-10 h-10 rounded-full"
                                            src={item.body.thumbnail}
                                            alt={item.body.title}
                                        />
                                        <div class="ps-3">
                                            <div class="text-base font-semibold">
                                                {item.body.title}
                                            </div>
                                            <div class="font-normal text-gray-500">
                                                {item.body.id}
                                            </div>
                                        </div>
                                    </th>
                                    <td class="px-6 py-4">
                                        $
                                        {item.body.price.toLocaleString(
                                            "es-CL",
                                        )}
                                    </td>
                                    <td class="px-6 py-4 text-center">
                                        <span
                                            class={`font-bold ${item.body.available_quantity < 5 ? "text-red-600" : "text-green-600"}`}
                                        >
                                            {item.body.available_quantity}
                                        </span>
                                    </td>
                                    <td class="px-6 py-4">
                                        {item.body.status === "active" ? (
                                            <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded-full border border-green-400">
                                                Activo
                                            </span>
                                        ) : (
                                            <span class="bg-yellow-100 text-yellow-800 text-xs font-medium px-2.5 py-0.5 rounded-full border border-yellow-400 italic">
                                                Pausado
                                            </span>
                                        )}
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            )
        }
        {error && <p class="mt-4 text-red-500 text-center">{error}</p>}
    </main>
</Layout>
