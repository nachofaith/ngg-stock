---
import Layout from '../layouts/Layout.astro';
import LoginForm from '../components/LoginForm.astro';

// 1. Revisamos si la cookie de sesión de tu app existe y es válida
const isAuthenticated = Astro.cookies.get('app_session')?.value === 'authenticated';

// 2. Si el usuario ya está autenticado, lo mandamos directo al dashboard
if (isAuthenticated) {
  return Astro.redirect('/dashboard');
}

// 3. Si no, Astro seguirá hacia abajo y mostrará el login normalmente
---

<Layout>
	<LoginForm />
</Layout>
